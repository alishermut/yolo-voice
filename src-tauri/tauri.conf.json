{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YOLO Voice",
  "version": "0.2.0",
  "identifier": "com.alish.yolo-voice",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "YOLO Voice",
        "width": 800,
        "height": 600,
        "minWidth": 600,
        "minHeight": 400
      },
      {
        "label": "pill",
        "url": "pill.html",
        "title": "",
        "width": 280,
        "height": 50,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../sidecar/transcribe.py",
      "../sidecar/requirements.txt",
      "../sidecar/default_profiles.json",
      "../sidecar/industry_packs/*"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/alishermut/yolo_voice/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCMjkxRkRERUM3MkQ4MTYKUldRVzJITHMzUjhwSzNQdG9ZdXY1ZUNLUUZzV2Z5MlJMR1VxZ1BJdGZZL1owRGQ0NytjUzhTTGoK"
    }
  }
}
