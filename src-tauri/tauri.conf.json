{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YOLO Voice",
  "version": "0.5.1",
  "identifier": "com.alish.yolo-voice",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "YOLO Voice",
        "width": 800,
        "height": 600,
        "minWidth": 600,
        "minHeight": 400
      },
      {
        "label": "pill",
        "url": "pill.html",
        "title": "",
        "width": 280,
        "height": 50,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost https://github.com https://api.github.com; img-src 'self' asset: http://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/default_profiles.json",
      "resources/industry_packs/*",
      "resources/silero_vad_v5.onnx"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/alishermut/yolo_voice/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ3RjIyOUM4NzYzNDk2OEYKUldTUGxqUjJ5Q255UnpRZTVDYWJSZXE1MmFqY05KRCtRR3locGovYTAyU0FqQndaZ3lxRHdSOVQK"
    }
  }
}
